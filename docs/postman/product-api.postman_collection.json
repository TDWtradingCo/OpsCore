            "body": {
              "mode": "raw",
              "raw": "{\n  \"variantCode\": 0,\n  \"variantType\": \"Colour\",\n  \"variantValue\": \"Blue\",\n  \"condition\": \"Open Box\",\n  \"quantity\": 200,\n  \"imageUrl\": \"https://example.com/variant-image-updated.jpg\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/variant/{{variantId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "variant",
