  "item": [
    {
      "name": "Health Check",
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "health"
          ]
        },
        "description": "Checks whether the backend is running and whether Supabase is configured."
      },
      "response": [
        {
          "name": "Example 200",
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": "{\n  \"status\": \"ok\",\n  \"service\": \"tdot-dashboard-backend\",\n  \"supabase\": {\n    \"configured\": true,\n    \"serviceRoleEnabled\": true\n  }\n}"
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login With Supabase Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Supabase login succeeded', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "const auth = pm.response.json();",
                  "if (auth.access_token) {",
                  "  pm.collectionVariables.set('accessToken', auth.access_token);",
                  "}",
                  "if (auth.refresh_token) {",
                  "  pm.collectionVariables.set('refreshToken', auth.refresh_token);",
                  "}",
                  "if (auth.user && auth.user.id) {",
                  "  pm.collectionVariables.set('supabaseUserId', auth.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "apikey",
                "value": "{{supabaseAnonKey}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{authEmail}}\",\n  \"password\": \"{{authPassword}}\"\n}"
            },
            "url": {
              "raw": "{{supabaseUrl}}/auth/v1/token?grant_type=password",
              "host": [
                "{{supabaseUrl}}"
              ],
              "path": [
                "auth",
                "v1",
                "token"
              ],
              "query": [
                {
                  "key": "grant_type",
                  "value": "password"
                }
              ]
            },
            "description": "Logs in with Supabase email/password auth and stores `accessToken`, `refreshToken`, and `supabaseUserId` as collection variables."
          },
          "response": [
            {
              "name": "Example 200",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"access_token\": \"<access-token>\",\n  \"refresh_token\": \"<refresh-token>\",\n  \"token_type\": \"bearer\",\n  \"expires_in\": 3600,\n  \"user\": {\n    \"id\": \"01e5ba90-6f7e-4c57-83b8-ae132819a371\",\n    \"email\": \"user@example.com\"\n  }\n}"
            }
          ]
        }
      ]
    },
